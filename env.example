BOT_TOKEN=
ADMIN_IDS=
BOT_USERNAME=
# Необязательно: пусто = бот создаст ключ сам в data/.fernet_key
FERNET_KEY=
DB_PATH=data/store.db

# Playerok. Пусто = ручной режим (/issue).
# F12 -> Application -> Cookies -> playerok.com: скопировать token и __ddg3
PLAYEROK_COOKIES=
# Тот же User-Agent, что в браузере, где вы вошли на playerok.com
PLAYEROK_USER_AGENT=
# Прокси, если IP сервера не проходит антибот-проверку. Необязательно.
# Формат: http://user:pass@host:port
PLAYEROK_PROXY=

# true = после аренды аккаунт ждёт вашей проверки (/free), а не сдаётся сразу
RENTAL_MAINTENANCE=false
